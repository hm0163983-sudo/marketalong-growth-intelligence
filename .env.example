# Copy to .env for local testing. NEVER commit the real .env.
# Local run needs NONE of these — it falls back to preview mode + skips Sheets.

# Email: keep false until you've reviewed previews in output/previews/
EMAIL_SEND_ENABLED=false
EMAIL_RECIPIENT=you@example.com

# Gmail SMTP (App Password, not your login password). Only used when EMAIL_SEND_ENABLED=true.
SMTP_USERNAME=youraddress@gmail.com
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_FROM=youraddress@gmail.com

# Google Sheets (service account). Paste the full JSON as one line. Optional locally.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
